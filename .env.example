# Local development defaults to Docker when these are unset.
DATABASE_URL=
DATABASE_DIRECT_URL=

# Single-owner admin authentication. Generate a bcrypt hash and a random session secret.
# Never expose these through NEXT_PUBLIC_ variables.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Operator-only staging commands. Never expose these with NEXT_PUBLIC_.
STAGING_DATABASE_URL=
STAGING_DATABASE_DIRECT_URL=

# Media storage. Local is the default for development; production must use r2.
MEDIA_STORAGE_PROVIDER=local

# Docker/local persistent media volume.
# Host `npm run dev` consumes the same bind-mounted directory used by Docker.
# If the Next.js app runs in a container, use /data/media instead.
MEDIA_LOCAL_ROOT=./.data/media
MEDIA_LOCAL_PUBLIC_PATH=/api/media

# Cloudflare R2. Required when MEDIA_STORAGE_PROVIDER=r2; never commit values.
MEDIA_R2_ENDPOINT=
MEDIA_R2_BUCKET=
MEDIA_R2_ACCESS_KEY_ID=
MEDIA_R2_SECRET_ACCESS_KEY=
MEDIA_R2_REGION=auto
MEDIA_PUBLIC_BASE_URL=https://media.dechive.dev
