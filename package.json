{
  "name": "dechive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/sync-images.ts && next dev",
    "build": "tsx scripts/check-content.ts && tsx scripts/sync-images.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "check:content": "tsx scripts/check-content.ts",
    "verify:editor-runtime": "tsx scripts/editor-runtime/verify.ts",
    "verify:editor-browser": "playwright test scripts/editor-runtime/browser.spec.ts --reporter=line --workers=1",
    "verify:editor-security": "tsx scripts/editor-runtime/security-verify.ts",
    "db:up": "tsx scripts/db/up.ts",
    "db:status": "docker compose -f docker-compose.db.yml ps",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:logs": "docker compose -f docker-compose.db.yml logs --tail 100 -f postgres",
    "db:reset": "tsx scripts/db/reset.ts",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "dev:cms": "npm run db:up && npm run db:migrate && npm run dev",
    "test:db": "tsx scripts/db/test.ts",
    "verify:database": "npm run db:reset && npm run db:migrate && npm run test:db",
    "verify:content-import": "npm run db:reset && npm run db:migrate && tsx scripts/content-import/verify.ts",
    "verify:staging-local": "npm run db:reset && npm run db:migrate && tsx scripts/staging/verify.ts",
    "verify:import-recovery": "npm run db:reset && npm run db:migrate && tsx scripts/content-import/failure-recovery.ts",
    "staging:preflight": "tsx scripts/staging/preflight.ts",
    "staging:cms-preflight": "tsx scripts/staging/cms-preflight.ts",
    "staging:stage15-backup": "tsx scripts/staging/stage15-backup.ts",
    "staging:stage15-migrate": "tsx scripts/staging/stage15-migrate.ts",
    "staging:stage15-final": "tsx scripts/staging/stage15-final-check.ts",
    "staging:verify-vercel-cms": "tsx scripts/staging/verify-vercel-cms.ts",
    "staging:verify-stage15": "tsx scripts/staging/verify-stage15-vercel.ts",
    "staging:verify-stage16": "tsx scripts/staging/verify-stage16-vercel.ts",
    "staging:verify-stage17": "tsx scripts/staging/verify-stage17-vercel.ts",
    "staging:migrate": "tsx scripts/staging/migrate.ts",
    "staging:execute": "tsx scripts/staging/execute.ts",
    "staging:backup": "tsx scripts/staging/backup.ts",
    "staging:latency": "tsx scripts/staging/latency.ts",
    "staging:restore-verify": "tsx scripts/staging/restore-verify.ts",
    "verify:admin-knowledge": "npm run db:reset && npm run db:migrate && tsx scripts/admin/verify-knowledge-flow.ts",
    "verify:knowledge-publish": "npm run db:reset && npm run db:migrate && tsx scripts/admin/verify-knowledge-publish.ts",
    "verify:lecture-publish": "npm run db:reset && npm run db:migrate && tsx scripts/admin/verify-lecture-publish.ts",
    "verify:admin-browser": "npm run db:reset && npm run db:migrate && playwright test scripts/admin/knowledge-browser.spec.ts --reporter=line --workers=1",
    "verify:admin-edit-browser": "playwright test scripts/admin/knowledge-edit-browser.spec.ts --reporter=line --workers=1",
    "verify:admin-auth": "npm run db:reset && npm run db:migrate && tsx scripts/admin/verify-auth-browser.ts",
    "translate": "tsx scripts/translate.ts"
  },
  "dependencies": {
    "@google-analytics/data": "^6.0.0",
    "@supabase/supabase-js": "^2.103.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/html": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@types/three": "^0.185.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.6",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.6",
    "three": "^0.185.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
